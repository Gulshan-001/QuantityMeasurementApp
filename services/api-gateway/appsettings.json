{
  "Jwt": {
    "Key": "THIS_IS_MY_SUPER_SECRET_KEY_1234567890"
  },

  "Services": {
    "Auth":       "http://auth-service:5001",
    "Compare":    "http://compare-service:5002",
    "Convert":    "http://convert-service:5003",
    "Arithmetic": "http://arithmetic-service:5004"
  },

  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/api/auth/{**catch-all}" }
      },
      "compare-route": {
        "ClusterId": "compare-cluster",
        "Match": {
          "Path": "/api/Quantity/compare",
          "Methods": [ "POST" ]
        }
      },
      "convert-route": {
        "ClusterId": "convert-cluster",
        "Match": {
          "Path": "/api/Quantity/convert",
          "Methods": [ "POST" ]
        }
      },
      "arithmetic-add-route": {
        "ClusterId": "arithmetic-cluster",
        "Match": {
          "Path": "/api/Quantity/add",
          "Methods": [ "POST" ]
        }
      },
      "arithmetic-subtract-route": {
        "ClusterId": "arithmetic-cluster",
        "Match": {
          "Path": "/api/Quantity/subtract",
          "Methods": [ "POST" ]
        }
      },
      "arithmetic-divide-route": {
        "ClusterId": "arithmetic-cluster",
        "Match": {
          "Path": "/api/Quantity/divide",
          "Methods": [ "POST" ]
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://auth-service:5001" }
        }
      },
      "compare-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://compare-service:5002" }
        }
      },
      "convert-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://convert-service:5003" }
        }
      },
      "arithmetic-cluster": {
        "Destinations": {
          "destination1": { "Address": "http://arithmetic-service:5004" }
        }
      }
    }
  },

  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*"
}
